---
import Layout from '@shared/layouts/Layout.astro';
---

<Layout title="Cargando...">
  <main class="min-h-screen bg-chalk flex flex-col items-center justify-center p-4">
    <div class="flex flex-col items-center gap-4 animate-pulse">
      <!-- Icono de portapapeles/reportes con estética monocromática -->
      <svg class="w-12 h-12 text-graphite" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
        <rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect>
        <path d="M9 14h6"></path>
        <path d="M9 18h6"></path>
        <path d="M9 10h6"></path>
      </svg>
    </div>
  </main>
</Layout>

<script>
  // Redirección inmediata en el cliente usando replace para evitar ensuciar el historial del navegador
  window.location.replace('/dashboard');
</script>


