---
import Layout from '@shared/layouts/Layout.astro';
import RegisterCommitteeForm from '@modules/committee/ui/RegisterCommitteeForm';

const apiUrl = import.meta.env.PUBLIC_API_URL ?? '';
---

<Layout title="Fundar Comité — Reportes Barriales">
  <main class="min-h-screen bg-chalk flex items-center justify-center p-4 py-12">
    <div class="w-full max-w-sm">

      <div class="mb-8">
        <p class="text-xs font-medium text-concrete uppercase tracking-widest mb-3">
          Infraestructura Urbana · Guayaquil
        </p>
        <h1 class="text-2xl font-semibold text-graphite">
          Fundar un comité barrial
        </h1>
        <p class="text-sm text-concrete mt-1">
          Regístrate como presidente fundador de tu comité de barrio.
        </p>
      </div>

      <div class="bg-chalk border border-hairline rounded-xl p-6">
        <RegisterCommitteeForm client:load apiUrl={apiUrl} />
      </div>

      <p class="text-center text-sm text-concrete mt-4">
        ¿Ya tienes una cuenta?{' '}
        <a href="/login" class="text-graphite font-medium underline underline-offset-2">
          Inicia sesión
        </a>
      </p>

    </div>
  </main>
</Layout>
