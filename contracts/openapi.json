{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "Neighborhood Reports API",
    "description": "API para el sistema de reportes y comités barriales."
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "LoginResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "token": {
                "type": "string"
              }
            },
            "required": [
              "token"
            ]
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "MeResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "number"
              },
              "nombre": {
                "type": "string"
              },
              "usuario": {
                "type": "string"
              },
              "rol": {
                "type": "string"
              },
              "barrioId": {
                "type": "number",
                "nullable": true
              }
            },
            "required": [
              "id",
              "nombre",
              "usuario",
              "rol",
              "barrioId"
            ]
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "RegisterCommitteeResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "comiteId": {
                "type": "number"
              },
              "usuarioId": {
                "type": "number"
              },
              "miembroId": {
                "type": "number"
              }
            },
            "required": [
              "comiteId",
              "usuarioId",
              "miembroId"
            ]
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "RegisterUserResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "number"
              },
              "nombre": {
                "type": "string"
              },
              "usuario": {
                "type": "string"
              },
              "rol": {
                "type": "string"
              },
              "barrioId": {
                "type": "number"
              },
              "fechaRegistro": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "nombre",
              "usuario",
              "rol",
              "barrioId"
            ]
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "ProvincesResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "number"
                },
                "nombre": {
                  "type": "string"
                },
                "fechaCreacion": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "required": [
                "id",
                "nombre"
              ]
            }
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "CitiesResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "number"
                },
                "provinciaId": {
                  "type": "number"
                },
                "nombre": {
                  "type": "string"
                },
                "fechaCreacion": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "required": [
                "id",
                "provinciaId",
                "nombre"
              ]
            }
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "NeighborhoodsResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "number"
                },
                "ciudadId": {
                  "type": "number"
                },
                "nombre": {
                  "type": "string"
                },
                "fechaCreacion": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "required": [
                "id",
                "ciudadId",
                "nombre"
              ]
            }
          }
        },
        "required": [
          "message",
          "data"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "summary": "Iniciar sesión",
        "description": "Permite a los usuarios del sistema iniciar sesión y obtener un token JWT firmado.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "usuario": {
                    "type": "string",
                    "minLength": 3,
                    "pattern": "^[a-z0-9_]+$"
                  },
                  "contrasena": {
                    "type": "string",
                    "minLength": 6
                  }
                },
                "required": [
                  "usuario",
                  "contrasena"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Autenticación exitosa.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "El payload enviado no cumple con las validaciones requeridas."
          },
          "401": {
            "description": "El nombre de usuario o la contraseña son incorrectos."
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Registrar usuario",
        "description": "Permite registrar un nuevo usuario en la plataforma con el rol de ciudadano.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nombre": {
                    "type": "string",
                    "minLength": 3
                  },
                  "usuario": {
                    "type": "string",
                    "minLength": 3,
                    "pattern": "^[a-z0-9_]+$"
                  },
                  "contrasena": {
                    "type": "string",
                    "minLength": 6
                  },
                  "barrioId": {
                    "type": "integer",
                    "minimum": 0,
                    "exclusiveMinimum": true
                  }
                },
                "required": [
                  "nombre",
                  "usuario",
                  "contrasena",
                  "barrioId"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuario registrado exitosamente.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterUserResponse"
                }
              }
            }
          },
          "400": {
            "description": "El payload enviado no cumple con las validaciones requeridas."
          },
          "404": {
            "description": "Barrio no encontrado."
          },
          "409": {
            "description": "Conflicto: El nombre de usuario ya está en uso."
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "summary": "Obtener perfil del usuario",
        "description": "Recupera el perfil del usuario autenticado que emite la solicitud.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Perfil de usuario recuperado exitosamente.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponse"
                }
              }
            }
          },
          "401": {
            "description": "No autorizado o token JWT inválido."
          },
          "404": {
            "description": "Usuario no encontrado."
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/api/auth/register-leader": {
      "post": {
        "summary": "Registrar líder y fundar comité",
        "description": "Permite fundar un comité barrial y dar de alta a su líder de forma pública en un solo paso.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nombre": {
                    "type": "string",
                    "minLength": 3
                  },
                  "usuario": {
                    "type": "string",
                    "minLength": 3,
                    "pattern": "^[a-z0-9_]+$"
                  },
                  "contrasena": {
                    "type": "string",
                    "minLength": 6
                  },
                  "barrioId": {
                    "type": "integer",
                    "minimum": 0,
                    "exclusiveMinimum": true
                  }
                },
                "required": [
                  "nombre",
                  "usuario",
                  "contrasena",
                  "barrioId"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Comité barrial y líder registrados exitosamente.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterCommitteeResponse"
                }
              }
            }
          },
          "400": {
            "description": "El payload enviado no cumple con las validaciones requeridas."
          },
          "404": {
            "description": "Barrio no encontrado."
          },
          "409": {
            "description": "Conflicto por duplicidad de usuario o de comité en el barrio."
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/api/territory/province": {
      "get": {
        "summary": "Obtener todas las provincias",
        "description": "Recupera la lista completa de provincias registradas en el sistema para su uso en formularios de registro.",
        "responses": {
          "200": {
            "description": "Catálogo de provincias recuperado con éxito.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProvincesResponse"
                }
              }
            }
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/api/territory/city": {
      "get": {
        "summary": "Obtener ciudades por provincia",
        "description": "Recupera las ciudades asociadas a una provincia específica mediante su ID.",
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true
            },
            "required": true,
            "name": "provinceId",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Ciudades recuperadas con éxito.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CitiesResponse"
                }
              }
            }
          },
          "400": {
            "description": "El ID de la provincia proporcionado es inválido."
          },
          "404": {
            "description": "Provincia no encontrada."
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/api/territory/neighborhood": {
      "get": {
        "summary": "Obtener barrios por ciudad",
        "description": "Recupera los barrios asociados a una ciudad específica mediante su ID.",
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true
            },
            "required": true,
            "name": "cityId",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Barrios recuperados con éxito.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NeighborhoodsResponse"
                }
              }
            }
          },
          "400": {
            "description": "El ID de la ciudad proporcionado es inválido."
          },
          "404": {
            "description": "Ciudad no encontrada."
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    }
  }
}