{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "Neighborhood Reports API",
    "description": "API para el sistema de reportes y comités barriales."
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "LoginResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "token": {
                "type": "string"
              }
            },
            "required": [
              "token"
            ]
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "MeResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "number"
              },
              "nombre": {
                "type": "string"
              },
              "usuario": {
                "type": "string"
              },
              "rol": {
                "type": "string"
              },
              "barrioId": {
                "type": "number",
                "nullable": true
              }
            },
            "required": [
              "id",
              "nombre",
              "usuario",
              "rol",
              "barrioId"
            ]
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "RegisterCommitteeResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "comiteId": {
                "type": "number"
              },
              "usuarioId": {
                "type": "number"
              },
              "miembroId": {
                "type": "number"
              }
            },
            "required": [
              "comiteId",
              "usuarioId",
              "miembroId"
            ]
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "RegisterCommitteeMemberResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "miembroId": {
                "type": "number"
              }
            },
            "required": [
              "miembroId"
            ]
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "CommitteeMembersListResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "number"
                },
                "usuarioId": {
                  "type": "number"
                },
                "nombre": {
                  "type": "string"
                },
                "usuario": {
                  "type": "string"
                },
                "rol": {
                  "type": "string",
                  "enum": [
                    "Presidente",
                    "Secretario",
                    "Vocal"
                  ]
                },
                "fechaRegistro": {
                  "type": "string",
                  "nullable": true
                }
              },
              "required": [
                "id",
                "usuarioId",
                "nombre",
                "usuario",
                "rol"
              ]
            }
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "RegisterUserResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "number"
              },
              "nombre": {
                "type": "string"
              },
              "usuario": {
                "type": "string"
              },
              "rol": {
                "type": "string"
              },
              "barrioId": {
                "type": "number"
              },
              "fechaRegistro": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "nombre",
              "usuario",
              "rol",
              "barrioId"
            ]
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "ProvincesResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "number"
                },
                "nombre": {
                  "type": "string"
                },
                "fechaCreacion": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "required": [
                "id",
                "nombre"
              ]
            }
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "CitiesResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "number"
                },
                "provinciaId": {
                  "type": "number"
                },
                "nombre": {
                  "type": "string"
                },
                "fechaCreacion": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "required": [
                "id",
                "provinciaId",
                "nombre"
              ]
            }
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "NeighborhoodsResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "number"
                },
                "ciudadId": {
                  "type": "number"
                },
                "nombre": {
                  "type": "string"
                },
                "fechaCreacion": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "required": [
                "id",
                "ciudadId",
                "nombre"
              ]
            }
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "NeighborsResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "number"
                },
                "nombre": {
                  "type": "string"
                },
                "usuario": {
                  "type": "string"
                },
                "fechaRegistro": {
                  "type": "string"
                }
              },
              "required": [
                "id",
                "nombre",
                "usuario"
              ]
            }
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "StorageSignatureResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "signature": {
                "type": "string"
              },
              "timestamp": {
                "type": "number"
              },
              "folder": {
                "type": "string"
              },
              "apiKey": {
                "type": "string"
              },
              "cloudName": {
                "type": "string"
              }
            },
            "required": [
              "signature",
              "timestamp",
              "folder",
              "apiKey",
              "cloudName"
            ]
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "CreateReportResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "number"
              },
              "usuarioId": {
                "type": "number"
              },
              "barrioId": {
                "type": "number"
              },
              "direccion": {
                "type": "string"
              },
              "ubicacion": {
                "type": "string"
              },
              "fotoUrl": {
                "type": "string"
              },
              "estado": {
                "type": "string"
              },
              "descripcion": {
                "type": "string"
              },
              "fechaCreacion": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "usuarioId",
              "barrioId",
              "direccion",
              "ubicacion",
              "fotoUrl",
              "estado",
              "descripcion"
            ]
          }
        },
        "required": [
          "message",
          "data"
        ]
      },
      "ListActiveReportsResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "number"
                },
                "usuarioId": {
                  "type": "number"
                },
                "barrioId": {
                  "type": "number"
                },
                "direccion": {
                  "type": "string"
                },
                "ubicacion": {
                  "type": "string"
                },
                "fotoUrl": {
                  "type": "string"
                },
                "estado": {
                  "type": "string"
                },
                "descripcion": {
                  "type": "string"
                },
                "fechaCreacion": {
                  "type": "string"
                },
                "fechaActualizacion": {
                  "type": "string"
                }
              },
              "required": [
                "id",
                "usuarioId",
                "barrioId",
                "direccion",
                "ubicacion",
                "fotoUrl",
                "estado",
                "descripcion"
              ]
            }
          }
        },
        "required": [
          "message",
          "data"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "summary": "Iniciar sesión",
        "description": "Permite a los usuarios del sistema iniciar sesión y obtener un token JWT firmado.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "usuario": {
                    "type": "string",
                    "minLength": 3,
                    "pattern": "^[a-z0-9_]+$"
                  },
                  "contrasena": {
                    "type": "string",
                    "minLength": 6
                  }
                },
                "required": [
                  "usuario",
                  "contrasena"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Autenticación exitosa.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "El payload enviado no cumple con las validaciones requeridas."
          },
          "401": {
            "description": "El nombre de usuario o la contraseña son incorrectos."
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Registrar usuario",
        "description": "Permite registrar un nuevo usuario en la plataforma con el rol de ciudadano.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nombre": {
                    "type": "string",
                    "minLength": 3
                  },
                  "usuario": {
                    "type": "string",
                    "minLength": 3,
                    "pattern": "^[a-z0-9_]+$"
                  },
                  "contrasena": {
                    "type": "string",
                    "minLength": 6
                  },
                  "barrioId": {
                    "type": "integer",
                    "minimum": 0,
                    "exclusiveMinimum": true
                  }
                },
                "required": [
                  "nombre",
                  "usuario",
                  "contrasena",
                  "barrioId"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuario registrado exitosamente.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterUserResponse"
                }
              }
            }
          },
          "400": {
            "description": "El payload enviado no cumple con las validaciones requeridas."
          },
          "404": {
            "description": "Barrio no encontrado."
          },
          "409": {
            "description": "Conflicto: El nombre de usuario ya está en uso."
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "summary": "Obtener perfil del usuario",
        "description": "Recupera el perfil del usuario autenticado que emite la solicitud.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Perfil de usuario recuperado exitosamente.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponse"
                }
              }
            }
          },
          "401": {
            "description": "No autorizado o token JWT inválido."
          },
          "404": {
            "description": "Usuario no encontrado."
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/api/auth/register-leader": {
      "post": {
        "summary": "Registrar líder y fundar comité",
        "description": "Permite fundar un comité barrial y dar de alta a su líder de forma pública en un solo paso.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nombre": {
                    "type": "string",
                    "minLength": 3
                  },
                  "usuario": {
                    "type": "string",
                    "minLength": 3,
                    "pattern": "^[a-z0-9_]+$"
                  },
                  "contrasena": {
                    "type": "string",
                    "minLength": 6
                  },
                  "barrioId": {
                    "type": "integer",
                    "minimum": 0,
                    "exclusiveMinimum": true
                  }
                },
                "required": [
                  "nombre",
                  "usuario",
                  "contrasena",
                  "barrioId"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Comité barrial y líder registrados exitosamente.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterCommitteeResponse"
                }
              }
            }
          },
          "400": {
            "description": "El payload enviado no cumple con las validaciones requeridas."
          },
          "404": {
            "description": "Barrio no encontrado."
          },
          "409": {
            "description": "Conflicto por duplicidad de usuario o de comité en el barrio."
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/api/territory/province": {
      "get": {
        "summary": "Obtener todas las provincias",
        "description": "Recupera la lista completa de provincias registradas en el sistema para su uso en formularios de registro.",
        "responses": {
          "200": {
            "description": "Catálogo de provincias recuperado con éxito.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProvincesResponse"
                }
              }
            }
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/api/territory/city": {
      "get": {
        "summary": "Obtener ciudades por provincia",
        "description": "Recupera las ciudades asociadas a una provincia específica mediante su ID.",
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true
            },
            "required": true,
            "name": "provinceId",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Ciudades recuperadas con éxito.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CitiesResponse"
                }
              }
            }
          },
          "400": {
            "description": "El ID de la provincia proporcionado es inválido."
          },
          "404": {
            "description": "Provincia no encontrada."
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/api/territory/neighborhood": {
      "get": {
        "summary": "Obtener barrios por ciudad",
        "description": "Recupera los barrios asociados a una ciudad específica mediante su ID.",
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true
            },
            "required": true,
            "name": "cityId",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Barrios recuperados con éxito.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NeighborhoodsResponse"
                }
              }
            }
          },
          "400": {
            "description": "El ID de la ciudad proporcionado es inválido."
          },
          "404": {
            "description": "Ciudad no encontrada."
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/api/committee/members": {
      "post": {
        "summary": "Registrar miembro del comité",
        "description": "Permite a un líder de comité barrial registrar nuevos miembros directivos (Secretario, Vocal).",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "usuarioId": {
                    "type": "integer",
                    "minimum": 0,
                    "exclusiveMinimum": true
                  },
                  "rolComite": {
                    "type": "string",
                    "enum": [
                      "Secretario",
                      "Vocal"
                    ]
                  }
                },
                "required": [
                  "usuarioId",
                  "rolComite"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Miembro del comité registrado exitosamente.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterCommitteeMemberResponse"
                }
              }
            }
          },
          "400": {
            "description": "El payload enviado no cumple con las validaciones requeridas."
          },
          "403": {
            "description": "Acceso denegado. Solo los líderes pueden realizar esta operación."
          },
          "404": {
            "description": "Comité no encontrado para el barrio del líder."
          },
          "409": {
            "description": "Conflicto: El nombre de usuario ya está en uso."
          },
          "500": {
            "description": "Error interno del servidor o configuración de seguridad."
          }
        }
      }
    },
    "/api/users/neighbors": {
      "get": {
        "summary": "Obtener vecinos elegibles del barrio",
        "description": "Recupera la lista de vecinos (ciudadanos regulares) del mismo barrio que el líder o miembro solicitante para poder ser asignados al comité.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Vecinos del barrio recuperados exitosamente.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NeighborsResponse"
                }
              }
            }
          },
          "400": {
            "description": "El usuario solicitante no pertenece a ningún barrio."
          },
          "401": {
            "description": "No autorizado o token JWT inválido."
          },
          "403": {
            "description": "Acceso denegado. Solo líderes y miembros pueden acceder."
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/api/committee/members/list": {
      "get": {
        "summary": "Obtener miembros del comité",
        "description": "Recupera la lista completa de los miembros directivos (Presidente, Secretario, Vocal) del comité del barrio del usuario autenticado.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Miembros del comité recuperados con éxito.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommitteeMembersListResponse"
                }
              }
            }
          },
          "400": {
            "description": "El usuario solicitante no pertenece a ningún barrio."
          },
          "401": {
            "description": "No autorizado o token JWT inválido."
          },
          "403": {
            "description": "Acceso denegado. Solo líderes y miembros pueden acceder."
          },
          "404": {
            "description": "Comité no encontrado para el barrio del usuario."
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/api/storage/signature": {
      "get": {
        "summary": "Obtener firma para subida directa de imágenes",
        "description": "Genera una firma criptográfica para permitir al frontend subir imágenes directamente a Cloudinary.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "Carpeta de destino en Cloudinary"
            },
            "required": false,
            "description": "Carpeta de destino en Cloudinary",
            "name": "folder",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Firma de Cloudinary generada con éxito.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StorageSignatureResponse"
                }
              }
            }
          },
          "401": {
            "description": "No autorizado o token JWT inválido."
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/api/incidents/create": {
      "post": {
        "summary": "Crear reporte de incidencia",
        "description": "Permite registrar un reporte de incidencia ciudadana en el barrio del usuario autenticado.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "direccion": {
                    "type": "string",
                    "minLength": 5,
                    "maxLength": 255
                  },
                  "ubicacion": {
                    "type": "string",
                    "pattern": "^-?\\d+(?:\\.\\d+)?\\s*,\\s*-?\\d+(?:\\.\\d+)?$"
                  },
                  "fotoUrl": {
                    "type": "string",
                    "format": "uri"
                  },
