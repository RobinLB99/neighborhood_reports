# ENTORNO
NODE_ENV="development"

# 🗄️ BASE DE DATOS (Neon Local & Cloud)
# NOTA: Al usar neon_local en desarrollo local, necesitas configurar las credenciales de Neon Cloud
NEON_API_KEY="tu_neon_api_key_aqui"
NEON_PROJECT_ID="tu_neon_project_id_aqui"
PARENT_BRANCH_ID="parent_branch_id"

# Desarrollo Local (A través del proxy docker neon_local)
# Nota: La URL de conexión local se conectará al puerto del proxy expuesto en docker-compose
DATABASE_URL="postgres://neon:npg@localhost:5432/neondb"

# Producción / Staging (Neon / Vercel Postgres directa)
# DATABASE_URL="postgres://usuario:password@host.neon.tech/dbname?sslmode=require"

# SEGURIDAD Y AUTENTICACIÓN
JWT_SECRET="una_cadena_larga_y_aleatoria_para_firmar_tokens"

# ALMACENAMIENTO DE ARCHIVOS (Vercel Blob - Requerido para pruebas locales)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_tu_token_secreto_local"


